# Skin Insight AI Configuration
# Copy this file to .env and modify as needed

# Application
APP_NAME="Skin Insight AI"
APP_VERSION="1.0.0"
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Image Settings
MAX_IMAGE_SIZE_MB=10
MIN_FACE_SIZE_PIXELS=100
MIN_IMAGE_RESOLUTION_WIDTH=256
MIN_IMAGE_RESOLUTION_HEIGHT=256

# Face Detection
FACE_DETECTION_CONFIDENCE_THRESHOLD=0.5

# Model Paths
INSIGHTFACE_MODEL_PATH=models/insightface
FACE_PARSING_MODEL_PATH=models/face_parsing

# LLM Settings (for AI explanations)
LLM_ENABLED=true
LLM_PROVIDER=mistral  # "mistral" or "gemini"
LLM_API_KEY=""  # Mistral API key
LLM_API_KEY_GEMINI=""  # Gemini API key (used when LLM_PROVIDER=gemini)
LLM_MODEL=mistral-small-latest  # Mistral: mistral-small-latest, Gemini: gemini-1.5-flash
LLM_TIMEOUT_SECONDS=30

# CORS
CORS_ORIGINS=["*"]

# Performance Targets
TARGET_FACE_DETECTION_MS=100
TARGET_FACE_PARSING_MS=150
TARGET_ANALYSIS_MS=300
TARGET_RECOMMENDATION_MS=20
TARGET_TOTAL_PIPELINE_MS=700
